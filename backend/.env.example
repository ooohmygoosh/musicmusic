PORT=8080
DATABASE_URL=postgres://postgres:postgres@db:5432/tpy
TPY_API_KEY=your_tianpuyue_key
TPY_BASE_URL=https://api.tianpuyue.cn
TPY_MODEL_SONG=TemPolor v3
TPY_MODEL_INSTRUMENTAL=TemPolor i3
CALLBACK_BASE=https://api.yourdomain.com
ADMIN_TOKEN=change_me_long_random


DEEPSEEK_ENABLED=true
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
COVER_IMAGE_ENABLED=false
COVER_IMAGE_API_KEY=your_cover_model_key
COVER_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
COVER_IMAGE_MODEL=doubao-seedream-4-0-250828
COVER_IMAGE_SIZE=1024x1024

REDIS_URL=redis://redis:6379
EXPLORE_POOL_SIZE=5
EXPLORE_SNIPPET_SECONDS_MIN=60
EXPLORE_SNIPPET_SECONDS_MAX=90
